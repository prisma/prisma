datasource db {
  provider = "sqlite"
}

generator client {
  provider                       = "prisma-client-ts"
  output                         = "./generated-exact-descriptor"
  internalExactDescriptorHelpers = ["User.findUnique:id:id,email,name", "User.findMany:take:id,email,name"]
}

model User {
  id    Int    @id
  email String
  name  String
}
