datasource db {
  provider = "sqlite"
}

generator client {
  provider                       = "prisma-client-ts"
  output                         = "./generated-exact-descriptor"
  internalExactDescriptorHelpers = ["User.findUnique:id:id,email,name", "User.findUnique:score:id,score", "User.findUnique:externalId:id,externalId", "User.findUnique:enabled:id,enabled", "User.findUnique:fingerprint:id,fingerprint", "User.findUnique:createdAt:id,createdAt", "User.findUnique:balance:id,balance", "User.findUnique:metadata:id,metadata", "User.findMany:take:id,email,name", "User.findFirst:email:id,email,name", "User.findFirstOrThrow:email:id,email", "template:Post.findUnique:id:blogPagePostV1", "template:Post.findUnique:slug:blogPagePostV1", "template:Post.findMany:authorId:blogFeedByAuthorPostListV1"]
}

model User {
  id         Int       @id
  email      String
  name       String
  avatar     String?
  score      Float     @unique
  externalId BigInt    @unique
  enabled    Boolean   @unique
  fingerprint Bytes    @unique
  createdAt  DateTime  @unique
  balance    Decimal   @unique
  metadata   Json      @unique
  posts      Post[]
  comments   Comment[]
}

model Category {
  id    Int    @id
  name  String
  slug  String @unique
  posts Post[]
}

model Tag {
  id    Int          @id
  name  String
  slug  String       @unique
  posts TagsOnPosts[]
}

model Post {
  id         Int            @id
  title      String
  slug       String         @unique
  content    String
  published  Boolean
  viewCount  Int
  createdAt  DateTime
  authorId   Int
  categoryId Int
  author     User           @relation(fields: [authorId], references: [id])
  category   Category       @relation(fields: [categoryId], references: [id])
  tags       TagsOnPosts[]
  comments   Comment[]
}

model TagsOnPosts {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id])
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
}

model Comment {
  id        Int      @id
  content   String
  createdAt DateTime
  postId    Int
  authorId  Int
  post      Post     @relation(fields: [postId], references: [id])
  author    User     @relation(fields: [authorId], references: [id])
}
